# JAH MemoryAgent Configuration
# Copy this file to .env and fill in your values.
# Do not commit .env.

QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

JAH_ENV=production
JAH_TIMEZONE=America/Mexico_City
JAH_DEBUG=false
# Required when the service is accessed from a non-loopback address.
JAH_API_KEY=
# Required only when signed local replication is enabled.
JAH_REPLICATION_KEY=

JAH_DATACORE_STORAGE=runtime/memory/datacore
JAH_HOT_STORAGE=runtime/memory/pyramid
JAH_SESSION_PATH=/tmp/jah_sessions

SALK_ENABLED=true
SALK_AUDIT_FILE=runtime/security/salk_audit.jahl
SALK_MAX_SECRET_SCAN_MATCHES=20
